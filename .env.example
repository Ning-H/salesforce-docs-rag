APP_ENV=local
LOG_LEVEL=INFO

# Embeddings
EMBEDDING_PROVIDER=local
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Vector store
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=
WEAVIATE_COLLECTION=SalesforceDocChunk

# Crawling and data paths
RAW_DOCS_PATH=data/raw/salesforce_docs.jsonl
CHUNKS_PATH=data/processed/salesforce_doc_chunks.jsonl
MAX_PAGES=200
CRAWL_SEED_URLS=https://developer.salesforce.com/docs/get_document/atlas.en-us.apexcode.meta,https://developer.salesforce.com/docs/get_document/atlas.en-us.api_rest.meta,https://developer.salesforce.com/docs/get_document/atlas.en-us.soql_sosl.meta

# API
API_HOST=0.0.0.0
API_PORT=8000
